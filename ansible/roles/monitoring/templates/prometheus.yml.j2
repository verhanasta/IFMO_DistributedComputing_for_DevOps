# ansible/roles/monitoring/templates/prometheus.yml.j2
global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node_exporter'
    static_configs:
      - targets: ['localhost:9100']

  - job_name: 'mysqld_exporter'
    static_configs:
      - targets: ['mysqld_exporter_monitor:9104']

  - job_name: 'mysql_master'
    static_configs:
      - targets: ['mysql_master:3306']
        labels:
          instance: 'mysql_master'
    relabel_configs:
      - source_labels: [__address__]
        target_label: __address__
        replacement: mysqld_exporter_monitor:9104